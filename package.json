{
  "name": "sanatana-dharma-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:api": "node server/index.mjs",
    "dev:vite": "vite",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:with-api": "concurrently -k \"npm:dev:api\" \"vite preview\""
  },
  "dependencies": {
    "cors": "^2.8.6",
    "d3-force": "^3.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "marked": "^18.0.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.10"
  }
}
