# Copy to .env in project root — loaded by the API server (dotenv).
# Admin UI (change in production)
ADMIN_PASSWORD=dev-admin-change-me
ADMIN_SECRET=change-admin-secret-in-production

# API port (default 3001)
PORT=3001

# Optional (production builds only): full origin of the API if the static site
# is hosted on a different domain. Leave UNSET for normal dev — the Vite dev
# server proxies /api to the CMS (see vite.config.js). Do NOT set this to
# http://127.0.0.1:3001 if you browse the app via your LAN IP or another device.
# VITE_API_URL=https://your-api.example.com

# Dev: use `npm run dev` (starts API + Vite). Plain `vite` alone has no CMS.
# After build: `npm start` serves both site + API on PORT (default 3001).
# Preview + API: `npm run preview:with-api` (API on 3001, preview on 4173).
